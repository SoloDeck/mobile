# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment secrets — never commit real .env
/.env
*.env
!.env.example

# Generated Dart files — commit only if CI cannot run build_runner
# Uncomment next lines to gitignore generated files:
# **/*.g.dart
# **/*.freezed.dart

# claude-code-harness (lifecycle) runtime state — keep out of git
.claude/state/
.claude/agent-memory/
.claude/logs/

# Android signing & Firebase
*.jks
*.keystore
android/app/google-services.json

# iOS signing & Firebase
ios/GoogleService-Info.plist
*.p12
*.pfx
*.mobileprovision
