# SoloDesk Mobile — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file.

# Backend API base URL
API_BASE_URL=http://localhost:8000

# Environment tag (development | staging | production)
APP_ENV=development

# Google Sign-In — Web/server OAuth client ID (used to mint an ID token for the backend).
# Leave empty to disable the Google button. Get this from Google Cloud Console.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# JWT token expiry (seconds) — must match backend config
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
